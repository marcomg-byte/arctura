{
  "name": "arctura",
  "packageManager": "yarn@4.11.0",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "url": "git+https://github.com/marcomg-byte/arctura.git"
  },
  "scripts": {
    "build": "yarn workspaces foreach --all --topological-dev run build",
    "build:app": "yarn workspace @arctura/app build",
    "build:atomics": "yarn workspace @arctura/atomics build",
    "build:theme": "yarn workspace @arctura/theme build",
    "clean": "yarn workspaces foreach --all --topological-dev run clean && rimraf coverage",
    "clean:app": "yarn workspace @arctura/app clean",
    "clean:atomics": "yarn workspace @arctura/atomics clean",
    "clean:theme": "yarn workspace @arctura/theme clean",
    "dev:app": "yarn workspace @arctura/app dev",
    "lint": "yarn workspaces foreach --all --topological-dev run lint",
    "lint:fix": "yarn workspaces foreach --all --topological-dev run lint:fix",
    "lint:app": "yarn workspace @arctura/app lint",
    "lint:atomics": "yarn workspace @arctura/atomics lint",
    "lint:theme": "yarn workspace @arctura/theme lint",
    "start:app": "yarn workspace @arctura/app start",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:atomics": "yarn workspace @arctura/atomics test",
    "test:theme": "yarn workspace @arctura/theme test",
    "theme:parse": "yarn workspace @arctura/theme theme:parse",
    "typecheck": "yarn workspaces foreach --all --topological-dev run typecheck",
    "typecheck:app": "yarn workspace @arctura/app typecheck",
    "typecheck:atomics": "yarn workspace @arctura/atomics typecheck",
    "typecheck:theme": "yarn workspace @arctura/theme typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@eslint/json": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-istanbul": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.3",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  }
}
