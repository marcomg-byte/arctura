{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"]
    },
    "rootDir": "../..",
    "noEmit": true
  },
  "include": [
    "lib/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx",
    "vite.config.ts",
    "vitest.config.mts",
    "../../vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
