{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"]
    },
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "./",
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": false
  },
  "include": ["lib/**/*.ts", "src/**/*.ts", "src/**/*.tsx", "tokens.json"]
}
