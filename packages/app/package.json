{
  "name": "@arctura/app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.11.0",
  "scripts": {
    "build": "next build",
    "clean": "rimraf .next out",
    "dev": "concurrently -k \"yarn theme:watch\" \"next dev\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "next start",
    "theme:run": "arctura-theme -t ./tokens.json -o ./app/theme.css",
    "theme:watch": "nodemon --watch ./tokens.json --ext json --exec \"yarn theme:run\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@arctura/atomics": "workspace:*",
    "@arctura/theme": "workspace:*",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "classnames": "^2.5.1",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.1",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
