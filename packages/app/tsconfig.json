{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "esModuleInterop": true,
    "incremental": true,
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "@arctura/atomics": ["../atomics/src/index.ts"],
      "@arctura/atomics/hooks": ["../atomics/lib/hooks.ts"],
      "@arctura/theme": ["../theme/src/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": ["node"]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["node_modules", "out"]
}
